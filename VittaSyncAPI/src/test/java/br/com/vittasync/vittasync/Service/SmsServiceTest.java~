package br.com.vittasync.vittasync.Service;

import br.com.vittasync.vittasync.Model.Usuario;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;

import static org.mockito.Mockito.*;

class SmsServiceTest {

    private SmsService service;
    private SmsService spyService;
    private Usuario usuario;

    @BeforeEach
    void setup() {
        service = new SmsService();
        spyService = Mockito.spy(service);

        usuario = new Usuario();
        usuario.setNome("João");
        usuario.setTelefone("999999999");
    }

    @Test
    void testEnviarCodigoChamaEnviarSMS() {
        doNothing().when(spyService).enviarSMS(anyString(), anyString());

        spyService.enviarCodigo("999999999", "12345");

        verify(spyService).enviarSMS(eq("999999999"), contains("Seu código de verificação é: 12345"));
    }

    @Test
    void testEnviarLembreteChamaEnviarSMS() {
        doNothing().when(spyService).enviarSMS(anyString(), anyString());

        spyService.enviarLembrete("999999999", "João", "Não esqueça de medir a pressão");

        verify(spyService).enviarSMS(eq("999999999"), contains("Olá, João. Não esqueça de medir a pressão"));
    }

    @Test
    void testFormatarTelefoneBR() throws Exception {
        var method = SmsService.class.getDeclaredMethod("formatarTelefoneBR", String.class);
        method.setAccessible(true);

        String resultado = (String) method.invoke(service, "999999999");

        assert resultado.equals("+55999999999");
    }

    @Test
    void testEnviarSMSCapturaExcecao() throws Exception {
        var method = SmsService.class.getDeclaredMethod("enviarSMS", String.class, String.class);
        method.setAccessible(true);
        method.invoke(service, "telefone_invalido", "mensagem");
    }
}
