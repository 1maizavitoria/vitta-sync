package br.com.vittasync.vittasync.Repository;

import br.com.vittasync.vittasync.Model.Usuario;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.orm.jpa.DataJpaTest;
import org.springframework.boot.test.autoconfigure.jdbc.AutoConfigureTestDatabase;
import org.springframework.transaction.annotation.Transactional;

import java.time.LocalDate;
import java.time.LocalDateTime;
import java.util.Optional;
import java.util.UUID;

import static org.assertj.core.api.Assertions.assertThat;

@DataJpaTest
@Transactional
@AutoConfigureTestDatabase(replace = AutoConfigureTestDatabase.Replace.NONE)
class UsuarioRepositoryTest {

    @Autowired
    private UsuarioRepository usuarioRepository;

    @BeforeEach
    void limparBanco() {
        usuarioRepository.deleteAll();
    }

    private Usuario criarUsuario(String nome, String email, String cpf, String tipo) {
        Usuario u = new Usuario();
        u.setCpf(cpf);
        u.setNome(nome);
        u.setEmail(email);
        u.setTelefone("41" + UUID.randomUUID().toString().substring(0, 8));
        u.setSenha("senha123");
        u.setTipo(tipo);
        u.setDataNascimento(LocalDate.of(1990, 1, 1));
        u.setDataCadastro(LocalDateTime.now());
        return usuarioRepository.save(u);
    }

    @Test
    void testFindByEmail() {
        Usuario usuario = criarUsuario("Paciente Teste", "paciente@test.com", "12345678901", "PACIENTE");

        Optional<Usuario> resultado = usuarioRepository.findByEmail("paciente@test.com");

        assertThat(resultado).isPresent();
        assertThat(resultado.get().getNome()).isEqualTo("Paciente Teste");
    }

    @Test
    void testFindByCpf() {
        Usuario usuario = criarUsuario("Paciente 2", "paciente2@test.com", "98765432100", "PACIENTE");

        Optional<Usuario> resultado = usuarioRepository.findByCpf("98765432100");

        assertThat(resultado).isPresent();
        assertThat(resultado.get().getEmail()).isEqualTo("paciente2@test.com");
    }

    @Test
    void testExistsByEmail() {
        criarUsuario("Paciente 3", "paciente3@test.com", "11122233344", "PACIENTE");

        boolean existe = usuarioRepository.existsByEmail("paciente3@test.com");
        boolean naoExiste = usuarioRepository.existsByEmail("naoexiste@test.com");

        assertThat(existe).isTrue();
        assertThat(naoExiste).isFalse();
    }

    @Test
    void testExistsByCpf() {
        criarUsuario("Paciente 4", "paciente4@test.com", "55566677788", "PACIENTE");

        boolean existe = usuarioRepository.existsByCpf("55566677788");
        boolean naoExiste = usuarioRepository.existsByCpf("00011122233");

        assertThat(existe).isTrue();
        assertThat(naoExiste).isFalse();
    }
}
